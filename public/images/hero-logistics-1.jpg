<svg xmlns="http://www.w3.org/2000/svg" width="1920" height="1080" viewBox="0 0 1920 1080">
  <defs>
    <linearGradient id="bg1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#0c2340"/>
      <stop offset="50%" stop-color="#1a3a5c"/>
      <stop offset="100%" stop-color="#0a1628"/>
    </linearGradient>
    <radialGradient id="glow1" cx="30%" cy="40%" r="40%">
      <stop offset="0%" stop-color="#e87722" stop-opacity="0.15"/>
      <stop offset="100%" stop-color="#0c2340" stop-opacity="0"/>
    </radialGradient>
  </defs>
  <rect width="1920" height="1080" fill="url(#bg1)"/>
  <rect width="1920" height="1080" fill="url(#glow1)"/>
  <!-- Ship silhouette -->
  <g transform="translate(900,400)" opacity="0.12">
    <path d="M-80,0 L-100,-20 L100,-20 L80,0 L60,30 L-60,30 Z" fill="#e87722"/>
    <rect x="-30" y="-20" width="60" height="40" rx="5" fill="#e87722"/>
    <rect x="-10" y="-50" width="20" height="30" fill="#e87722"/>
  </g>
  <!-- Container boxes -->
  <g transform="translate(920,370)" opacity="0.08">
    <rect x="-25" y="-15" width="25" height="15" fill="#e87722"/>
    <rect x="0" y="-15" width="25" height="15" fill="#e87722"/>
    <rect x="-25" y="0" width="25" height="15" fill="#1a3a5c"/>
    <rect x="0" y="0" width="25" height="15" fill="#1a3a5c"/>
  </g>
  <!-- Wave lines -->
  <path d="M0,600 Q200,580 400,600 T800,600 T1200,600 T1600,600 T1920,600" stroke="#e87722" stroke-opacity="0.06" stroke-width="2" fill="none"/>
  <path d="M0,650 Q200,630 400,650 T800,650 T1200,650 T1600,650 T1920,650" stroke="#e87722" stroke-opacity="0.04" stroke-width="1.5" fill="none"/>
  <!-- Grid pattern -->
  <g opacity="0.03">
    <line x1="0" y1="0" x2="0" y2="1080" stroke="#e87722" stroke-width="0.5"/>
    <line x1="120" y1="0" x2="120" y2="1080" stroke="#e87722" stroke-width="0.5"/>
    <line x1="240" y1="0" x2="240" y2="1080" stroke="#e87722" stroke-width="0.5"/>
    <line x1="360" y1="0" x2="360" y2="1080" stroke="#e87722" stroke-width="0.5"/>
    <line x1="480" y1="0" x2="480" y2="1080" stroke="#e87722" stroke-width="0.5"/>
    <line x1="600" y1="0" x2="600" y2="1080" stroke="#e87722" stroke-width="0.5"/>
    <line x1="720" y1="0" x2="720" y2="1080" stroke="#e87722" stroke-width="0.5"/>
    <line x1="0" y1="120" x2="1920" y2="120" stroke="#e87722" stroke-width="0.5"/>
    <line x1="0" y1="240" x2="1920" y2="240" stroke="#e87722" stroke-width="0.5"/>
    <line x1="0" y1="360" x2="1920" y2="360" stroke="#e87722" stroke-width="0.5"/>
    <line x1="0" y1="480" x2="1920" y2="480" stroke="#e87722" stroke-width="0.5"/>
    <line x1="0" y1="600" x2="1920" y2="600" stroke="#e87722" stroke-width="0.5"/>
  </g>
</svg>
